# MusicFun 项目环境变量配置
# 复制此文件为 .env 并修改相应值

# ========== 项目基础配置 ==========
# 调试模式
DEBUG=false

# 项目版本
VERSION=1.0.0

# ========== 网易云音乐配置 ==========
# 基础URL
NETEASE_BASE_URL=https://music.163.com

# API URL
NETEASE_API_URL=https://music.163.com/api

# 请求超时时间（秒）
NETEASE_TIMEOUT=30

# 重试次数
NETEASE_RETRY_TIMES=3

# 重试延迟（秒）
NETEASE_RETRY_DELAY=1.0

# 请求间隔（秒）
NETEASE_REQUEST_DELAY=0.5

# 最大并发数
NETEASE_MAX_CONCURRENT=5

# Cookie（从浏览器复制，重要！）
# 格式：key1=value1; key2=value2; key3=value3
NETEASE_COOKIES=

# 代理地址（可选）
# 格式：http://user:pass@host:port 或 socks5://host:port
NETEASE_PROXY=

# ========== 爬虫通用配置 ==========
# 爬虫超时时间（秒）
SPIDER_TIMEOUT=30

# 爬虫重试次数
SPIDER_RETRY_TIMES=3

# 爬虫重试延迟（秒）
SPIDER_RETRY_DELAY=1.0

# 爬虫请求间隔（秒）
SPIDER_REQUEST_DELAY=0.5

# 爬虫最大并发数
SPIDER_MAX_CONCURRENT=10

# 爬虫代理（可选）
SPIDER_PROXY=

# ========== 存储配置 ==========
# 存储格式（json/csv/excel/sqlite）
STORAGE_FORMAT=json

# 数据库URL
# SQLite: sqlite:///data/music.db
# PostgreSQL: postgresql://user:pass@localhost/dbname
# MySQL: mysql://user:pass@localhost/dbname
DATABASE_URL=sqlite:///data/music.db

# 最大备份文件数
MAX_BACKUP_FILES=10

# 是否自动备份
AUTO_BACKUP=true

# 是否压缩备份
COMPRESS_BACKUP=true

# ========== 日志配置 ==========
# 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
LOG_LEVEL=INFO

# 日志文件名
LOG_FILE=musicfun.log

# 错误日志文件名
ERROR_FILE=musicfun_error.log

# 最大日志文件大小
MAX_FILE_SIZE=10MB

# 备份文件数量
BACKUP_COUNT=5

# 日志轮转周期
ROTATION=1 day

# 是否输出到控制台
CONSOLE_OUTPUT=true

# 是否输出到文件
FILE_OUTPUT=true

# ========== HTTP 配置 ==========
# User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# 是否验证SSL证书
VERIFY_SSL=true

# ========== 高级配置 ==========
# 数据目录（相对路径）
DATA_DIR=data

# 日志目录（相对路径）
LOG_DIR=logs

# 导出目录（相对路径）
EXPORT_DIR=exports

# 备份目录（相对路径）
BACKUP_DIR=backups
